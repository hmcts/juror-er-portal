{% from "govuk/components/table/macro.njk" import govukTable %}

{% set rows = [] %}
{% for upload in uploadHistoryList %}
  {% set rows = (rows.push([
    {
      text: upload.filename
    },
    {
      text: upload.fileSizeFormatted
    },
    {
      text: upload.uploadDate | makeDate | dateFilter(null, "DD MMM YYYY")
    }
  ]), rows) %}
{% endfor %}

<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">
    {{ govukTable({
      caption: text.UPLOAD_HISTORY.PAGE_HEADING,
      captionClasses: "govuk-visually-hidden",
      head: [
        {
          text: text.UPLOAD_HISTORY.COLUMN_HEADING_FILE_NAME,
          attributes: {
            "aria-sort": "none",
            "aria-label": text.UPLOAD_HISTORY.COLUMN_HEADING_FILE_NAME
          }
        },
        {
          text: text.UPLOAD_HISTORY.COLUMN_HEADING_FILE_SIZE,
          attributes: {
            "aria-sort": "none",
            "aria-label": text.UPLOAD_HISTORY.COLUMN_HEADING_FILE_SIZE
          }
        },
        {
          text: text.UPLOAD_HISTORY.COLUMN_HEADING_UPLOAD_DATE,
          attributes: {
            "aria-sort": "none",
            "aria-label": text.UPLOAD_HISTORY.COLUMN_HEADING_UPLOAD_DATE
          }
        }
      ],
      rows: rows
    }) }}
  </div>
</div>
